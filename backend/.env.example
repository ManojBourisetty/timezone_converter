# Timezone Converter API Configuration
# Backend environment variables

# MongoDB Configuration
MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net/timezone_converter?retryWrites=true&w=majority
DB_NAME=timezone_converter

# Server Configuration
HOST=0.0.0.0
PORT=8001
DEBUG=False

# CORS Configuration (comma-separated)
# For development
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# For production, use specific domains
# ALLOWED_ORIGINS=https://timezone-converter.com,https://api.timezone-converter.com

# Logging
LOG_LEVEL=INFO

# Security
API_RATE_LIMIT=100/minute
REQUEST_TIMEOUT=30

# Feature Flags
ENABLE_CACHE=True
CACHE_TTL=3600
ENABLE_MONITORING=True

# Note: NEVER commit this file with real credentials
# Use this as a template and populate with actual values
# Store secrets in AWS Secrets Manager in production
