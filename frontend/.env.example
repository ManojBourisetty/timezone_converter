# Timezone Converter Frontend Configuration

# API Configuration
REACT_APP_BACKEND_URL=http://localhost:8001

# For production use your actual API URL
# REACT_APP_BACKEND_URL=https://api.timezone-converter.com

# Feature Flags
REACT_APP_ENABLE_DEBUG=false
REACT_APP_ENABLE_ANALYTICS=false
REACT_APP_ENVIRONMENT=development

# API Configuration
REACT_APP_API_TIMEOUT=30000
REACT_APP_REQUEST_RETRY_COUNT=3

# Note: This file is safe to commit (no secrets)
# Environment variables in .env file are embedded in the build
# For sensitive data, use runtime configuration or AWS Secrets Manager
